<%- include('partials/header') %>
    <div class="else">
        <div class="card-container">
            <% if (shows && shows.episodes > 0) { %>
                <% shows.forEach(show => { %>
                   <div class="card-container">
                        <div class="card-info">
                            <h5><%= shows.name %></h5>
                            <p>Episodes <%= shows.episodes %></p>
                        </div>
                    </div> 
                <% }) %>
            <% } else { %>
                <div class="card-container">
                    <div class="card-info">
                        <h5>info not found</h5>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
<%- include('partials/footer') %>